# =============================================================
# AgroLink Environment Variables - Example Configuration
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# =============================================================

# --- DATABASE CONFIGURATION ---
DB_USER=agro_admin
DB_PASSWORD=your_secure_database_password_here
DB_NAME=agro_link_db
DB_HOST=postgres
DB_PORT=5432

# --- JWT SECURITY ---
# Generate a strong secret: openssl rand -hex 32
JWT_KEY=your_jwt_secret_key_here_minimum_256_bits

# --- CHAT ENCRYPTION ---
# AES key must be exactly 16, 24 or 32 characters
CHAT_AES_KEY=YourSecureAES16Key

# --- AWS S3 CONFIGURATION ---
# Create an IAM user with S3 permissions and add keys here
AWS_ACCESS_KEY=your_aws_access_key_id
AWS_SECRET_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=your-s3-bucket-name

# --- STRIPE PAYMENT CONFIGURATION ---
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRICE_ID=price_your_stripe_price_id

# --- CLIENT URL ---
CLIENT_BASE_URL=https://your-production-domain.com

# --- EMAIL (SMTP) CONFIGURATION ---
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_specific_password

# --- EXTERNAL API KEYS ---
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- CORS CONFIGURATION ---
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://your-production-domain.com

# --- NEXT.JS FRONTEND ---
NEXT_PUBLIC_API_URL=https://your-production-domain.com
NEXT_PUBLIC_S3_HOSTNAME=your-bucket-name.s3.ap-south-1.amazonaws.com

# --- JPA DDL MODE ---
# Use 'update' for development, 'validate' for production (with proper migrations)
JPA_DDL_AUTO=update

# --- GCP DEPLOYMENT (used in CI/CD) ---
GCP_VM_HOST=your.gcp.vm.ip.address
GCP_VM_USER=your_gcp_vm_username
# Create a GitHub PAT with read:packages scope and set this on the GCP VM as an env var
# This is NOT in GitHub Secrets - it is stored directly on the VM in /etc/environment or similar
GH_REGISTRY_TOKEN=your_github_pat_with_read_packages_scope
