# ==============================================
# AgroLink Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit the .env file to version control
# ==============================================

# --- DATABASE ---
DB_USER=
DB_PASSWORD=
DB_NAME=agro_link_db
DB_HOST=localhost
DB_PORT=5432
DDL_AUTO=update

# --- JWT ---
JWT_SECRET=
JWT_KEY=

# --- EMAIL (Gmail SMTP) ---
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# --- AWS S3 ---
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=

# --- STRIPE ---
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- FRONTEND ---
CLIENT_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000

# --- EXTERNAL APIS ---
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- CHAT ---
CHAT_AES_KEY=

# --- DEPLOYMENT (GitHub Actions / GCP) ---
SERVER_HOST=
SERVER_USER=
SERVER_SSH_KEY=
GH_PACKAGES_TOKEN=
